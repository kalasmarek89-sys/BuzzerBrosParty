# Server
PORT=3001
CLIENT_URL=http://localhost:5173

# Auth – change JWT_SECRET in production!
JWT_SECRET=change-me-in-production

# Email (SMTP) – leave empty to log codes to console in dev
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=BuzzerBros Party <noreply@buzzerbros.app>

# Client (prefix VITE_ is required by Vite)
VITE_SERVER_URL=http://localhost:3001
